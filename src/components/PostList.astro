---
interface Post {
  slug: string;
  data: {
    title: string;
    description: string;
    image?: string;
    date: Date;
    updated?: Date;
    tags?: string[];
  };
}

interface Props {
  posts: Post[];
  emptyMessage: string;
  basePath?: string;
  showTags?: boolean;
  showDate?: boolean;
}

const {
  posts,
  emptyMessage,
  basePath = "posts",
  // Tags are shown on the opened post, not in listings.
  showTags = false,
  showDate = true,
} = Astro.props;
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

{
  posts.map((post) => (
    <article
      class="post-card"
      data-tags={(post.data.tags ?? []).join(",")}
      data-search={`${post.data.title} ${post.data.description} ${(post.data.tags ?? []).join(" ")}`}
    >
      <div class="post-card-body">
        {post.data.image && (
          <a class="post-card-image" href={`${base}${basePath}/${post.slug}/`} aria-label={post.data.title}>
            <img src={post.data.image} alt="" loading="lazy" />
          </a>
        )}
        {showDate && (
          <time class="post-card-date" datetime={post.data.date.toISOString()}>
            {post.data.date.toLocaleDateString("en", {
              year: "numeric",
              month: "short",
              day: "numeric",
            })}
          </time>
        )}
        <h3>
          <a href={`${base}${basePath}/${post.slug}/`}>{post.data.title}</a>
        </h3>
        <p>{post.data.description}</p>
        {showTags && (post.data.tags ?? []).length > 0 && (
          <ul class="tags" aria-label="Tags">
            {(post.data.tags ?? []).map((tag) => (
              <li>
                <a href={`${base}tags/${tag}/`}>{tag}</a>
              </li>
            ))}
          </ul>
        )}
      </div>
    </article>
  ))
}

{posts.length === 0 && <p class="empty-state">{emptyMessage}</p>}
