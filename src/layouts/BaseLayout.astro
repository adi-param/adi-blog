---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  publishedTime?: string;
  modifiedTime?: string;
}

const {
  title,
  description = "Cybersecurity and DevOps notes by Adi.",
  image,
  type = "website",
  publishedTime,
  modifiedTime,
} = Astro.props;
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const site = Astro.site ?? new URL("https://adi-param.github.io");
const canonicalUrl = new URL(Astro.url.pathname, site).toString();
const imageUrl = new URL(image ?? `${base}site-preview.svg`, site).toString();

// Emitted only for production builds; the dev server injects its own HMR
// scripts that a strict policy would block. The theme toggle uses small inline
// scripts so the selected theme can be applied before the first paint.
const csp = [
  "default-src 'self'",
  "script-src 'self' 'unsafe-inline'",
  "style-src 'self' 'unsafe-inline'",
  "img-src 'self' https: data:",
  "object-src 'none'",
  "base-uri 'none'",
].join("; ");
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {import.meta.env.PROD && (
      <meta http-equiv="Content-Security-Policy" content={csp} />
    )}
    <meta name="color-scheme" content="light" data-color-scheme-meta />
    <meta name="theme-color" content="#eef6fb" data-theme-color-meta />
    <meta name="description" content={description} />
    <meta name="author" content="Adi" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title="Adi · Cybersecurity & DevOps" href={new URL(`${base}rss.xml`, site).toString()} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Adi · Cybersecurity & DevOps" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    <title>{title}</title>
    <script is:inline>
      (() => {
        const lightThemeColor = "#eef6fb";
        const darkThemeColor = "#0d1117";

        const getStoredTheme = () => {
          try {
            return localStorage.getItem("theme");
          } catch {
            return null;
          }
        };
        const normalizeTheme = (theme) =>
          theme === "light" || theme === "dark" ? theme : null;
        const storedTheme = normalizeTheme(getStoredTheme());
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const theme = storedTheme || (prefersDark ? "dark" : "light");
        const colorSchemeMeta = document.querySelector("[data-color-scheme-meta]");
        const themeColorMeta = document.querySelector("[data-theme-color-meta]");

        document.documentElement.dataset.theme = theme;
        document.documentElement.style.colorScheme =
          theme === "dark" ? "dark" : "only light";
        if (colorSchemeMeta) {
          colorSchemeMeta.setAttribute("content", theme === "dark" ? "dark" : "light");
        }
        if (themeColorMeta) {
          themeColorMeta.setAttribute(
            "content",
            theme === "dark" ? darkThemeColor : lightThemeColor
          );
        }
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <nav class="site-nav" aria-label="Main navigation">
        <a class="site-title" href={base}>
          <span>Adi</span>
          <span>Cybersecurity &amp; DevOps</span>
        </a>
        <div class="site-nav-actions">
          <div class="nav-links">
            <a href={`${base}about/`}>About</a>
            <a href="https://github.com/adi-param">GitHub</a>
          </div>
          <button
            class="theme-toggle"
            type="button"
            aria-label="Switch to dark theme"
            data-theme-toggle
          >
            <span class="theme-toggle-label">Theme</span>
            <span class="theme-toggle-track" aria-hidden="true">
              <span class="theme-toggle-thumb"></span>
            </span>
            <span class="theme-toggle-state" data-theme-toggle-state>Light</span>
          </button>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>Copyright Adi</p>
      <nav aria-label="Footer navigation">
        <a href="https://github.com/adi-param">GitHub</a>
        <a href="https://www.linkedin.com/in/adiparamkusam/">LinkedIn</a>
        <a href={`${base}rss.xml`}>RSS</a>
      </nav>
    </footer>
    <script is:inline>
      (() => {
        const button = document.querySelector("[data-theme-toggle]");
        const state = document.querySelector("[data-theme-toggle-state]");
        const colorSchemeMeta = document.querySelector("[data-color-scheme-meta]");
        const themeColorMeta = document.querySelector("[data-theme-color-meta]");
        const lightThemeColor = "#eef6fb";
        const darkThemeColor = "#0d1117";
        if (!button) return;

        const applyTheme = (theme) => {
          document.documentElement.dataset.theme = theme;
          document.documentElement.style.colorScheme =
            theme === "dark" ? "dark" : "only light";
          if (colorSchemeMeta) {
            colorSchemeMeta.setAttribute(
              "content",
              theme === "dark" ? "dark" : "light"
            );
          }
          if (themeColorMeta) {
            themeColorMeta.setAttribute(
              "content",
              theme === "dark" ? darkThemeColor : lightThemeColor
            );
          }
          if (state) {
            state.textContent = theme === "dark" ? "Dark" : "Light";
          }
          button.setAttribute(
            "aria-label",
            theme === "dark" ? "Switch to light theme" : "Switch to dark theme"
          );
        };

        applyTheme(document.documentElement.dataset.theme || "light");

        button.addEventListener("click", () => {
          const nextTheme =
            document.documentElement.dataset.theme === "dark" ? "light" : "dark";
          try {
            localStorage.setItem("theme", nextTheme);
          } catch {
            // The visible toggle should still work when storage is blocked.
          }
          applyTheme(nextTheme);
        });
      })();
    </script>
  </body>
</html>
