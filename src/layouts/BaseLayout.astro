---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Cybersecurity and DevOps notes by Adi.",
} = Astro.props;
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

// The published site ships no client-side JavaScript, so script-src can be
// locked to 'none'. Emitted only for production builds; the dev server injects
// its own HMR scripts that a strict policy would block.
const csp = [
  "default-src 'self'",
  "script-src 'none'",
  "style-src 'self' 'unsafe-inline'",
  "img-src 'self' https: data:",
  "object-src 'none'",
  "base-uri 'none'",
].join("; ");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {import.meta.env.PROD && (
      <meta http-equiv="Content-Security-Policy" content={csp} />
    )}
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <nav class="site-nav" aria-label="Main navigation">
        <a class="site-title" href={base}>
          <span>Adi</span>
          <span>Cybersecurity &amp; DevOps</span>
        </a>
        <div class="nav-links">
          <a href={`${base}cybersecurity/`}>Cybersecurity</a>
          <a href={`${base}networking/`}>Networking</a>
          <a href={`${base}about/`}>About</a>
          <a href="https://github.com/adi-param">GitHub</a>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
