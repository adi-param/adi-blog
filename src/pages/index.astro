---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PostList from "../components/PostList.astro";

const posts = (await getCollection("posts")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const tagCounts = posts.reduce<Map<string, number>>((counts, post) => {
  post.data.tags.forEach((tag) => {
    counts.set(tag, (counts.get(tag) ?? 0) + 1);
  });
  return counts;
}, new Map());
const topTags = [...tagCounts.entries()]
  .sort(([tagA, countA], [tagB, countB]) => countB - countA || tagA.localeCompare(tagB))
  .slice(0, 8);
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout
  title="Adi · Cybersecurity & DevOps"
  description="Cybersecurity, DevOps, cloud security, and infrastructure notes by Adi."
>
  <section class="home-about" aria-label="About me">
    <div>
      <p class="eyebrow">About me</p>
      <h2>Hi, I’m Adi.</h2>
    </div>
    <div>
      <p>
        I’m a Cybersecurity and DevSecOps engineer in Singapore. By day I keep
        cloud platforms and production systems safe; here I write down what I
        learn along the way — security concepts, architecture patterns, and
        hard-won lessons, explained the way I’d explain them to a colleague.
      </p>
      <a href={`${base}about/`}>
        More about me
      </a>
    </div>
  </section>

  {
    topTags.length > 0 && (
      <section class="tag-browser" aria-label="Browse by tag">
        <div class="section-heading home-section-heading">
          <h2>Top tags</h2>
          <p>Most used</p>
        </div>
        <ul>
          {topTags.map(([tag, count]) => (
            <li>
              <a href={`${base}tags/${tag}/`}>
                {tag}
                <span>{count}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  <section class="post-list" aria-label="All posts">
    <div class="section-heading home-section-heading">
      <h2>All posts</h2>
      <p>{posts.length} post{posts.length === 1 ? "" : "s"}</p>
    </div>
    <PostList posts={posts} emptyMessage="Posts will appear here as they are published." />
  </section>
</BaseLayout>
