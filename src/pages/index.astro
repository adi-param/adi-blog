---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PostList from "../components/PostList.astro";

const posts = (await getCollection("posts")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout
  title="Adi · Cybersecurity & DevOps"
  description="Cybersecurity, DevOps, cloud security, and infrastructure notes by Adi."
>
  <section class="home-about" aria-label="About me">
    <div>
      <p class="eyebrow">About me</p>
      <h2>Hi, I’m Adi.</h2>
    </div>
    <div>
      <p>
        I work on cybersecurity, cloud security, DevSecOps, and production
        infrastructure. This site is where I share technical explanations,
        architecture notes, and practical knowledge from those areas.
      </p>
      <a href={`${import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`}about/`}>
        More about me
      </a>
    </div>
  </section>

  <section class="post-list" aria-label="All posts">
    <div class="section-heading">
      <h2>All posts</h2>
      <p>{posts.length} post{posts.length === 1 ? "" : "s"}</p>
    </div>
    <PostList posts={posts} emptyMessage="Posts will appear here as they are published." />
  </section>
</BaseLayout>
